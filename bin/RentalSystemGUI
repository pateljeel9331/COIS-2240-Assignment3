import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.*;
import javafx.stage.Stage;
import java.time.LocalDate;
import java.util.List;

public class RentalSystemGUI extends Application {

    private final RentalSystem system = RentalSystem.getInstance();

    private ListView<String> vehicleListView = new ListView<>();
    private ListView<String> customerListView = new ListView<>();
    private ListView<String> historyListView = new ListView<>();

    private ComboBox<String> vehicleTypeCombo = new ComboBox<>();
    private TextField plateField = new TextField();
    private TextField makeField = new TextField();
    private TextField modelField = new TextField();
    private TextField yearField = new TextField();
    private TextField seatsField = new TextField();
    private TextField horsepowerField = new TextField();
    private CheckBox turboCheck = new CheckBox("Has Turbo");
    private CheckBox accessibleCheck = new CheckBox("Is Accessible");
    private TextField cargoField = new TextField();
    private CheckBox trailerCheck = new CheckBox("Has Trailer");

    private ComboBox<String> rentVehicleCombo = new ComboBox<>();
    private ComboBox<String> rentCustomerCombo = new ComboBox<>();
    private TextField rentAmountField = new TextField();

    private ComboBox<String> returnVehicleCombo = new ComboBox<>();
    private ComboBox<String> returnCustomerCombo = new ComboBox<>();
    private TextField returnFeesField = new TextField();

    @Override
    public void start(Stage primaryStage) {
        primaryStage.setTitle("Vehicle Rental System - GUI");

        TabPane tabPane = new TabPane();

        Tab vehiclesTab = createVehiclesTab();
        Tab customersTab = createCustomersTab();
        Tab rentReturnTab = createRentReturnTab();
        Tab historyTab = createHistoryTab();

        tabPane.getTabs().addAll(vehiclesTab, customersTab, rentReturnTab, historyTab);

        Scene scene = new Scene(tabPane, 900, 650);
        primaryStage.setScene(scene);
        primaryStage.show();

        refreshAll();
    }

    private Tab createVehiclesTab() {
        vehicleTypeCombo.getItems().addAll("Car", "SportCar", "Minibus", "PickupTruck");
        vehicleTypeCombo.setValue("Car");

        Button addVehicleBtn = new Button("Add Vehicle");
        addVehicleBtn.setOnAction(e -> addVehicle());

        Button refreshBtn = new Button("Refresh Vehicle List");
        refreshBtn.setOnAction(e -> refreshVehicles());

        GridPane grid = new GridPane();
        grid.setHgap(10);
        grid.setVgap(10);
        grid.setPadding(new Insets(15));

        grid.add(new Label("Vehicle Type:"), 0, 0);
        grid.add(vehicleTypeCombo, 1, 0);
        grid.add(new Label("Plate:"), 0, 1);
        grid.add(plateField, 1, 1);
        grid.add(new Label("Make:"), 0, 2);
        grid.add(makeField, 1, 2);
        grid.add(new Label("Model:"), 0, 3);
        grid.add(modelField, 1, 3);
        grid.add(new Label("Year:"), 0, 4);
        grid.add(yearField, 1, 4);
        grid.add(new Label("Seats / Extra:"), 0, 5);
        grid.add(seatsField, 1, 5);
        grid.add(new Label("Horsepower:"), 0, 6);
        grid.add(horsepowerField, 1, 6);
        grid.add(turboCheck, 1, 7);
        grid.add(accessibleCheck, 1, 8);
        grid.add(new Label("Cargo Size:"), 0, 9);
        grid.add(cargoField, 1, 9);
        grid.add(trailerCheck, 1, 10);

        VBox vbox = new VBox(10, grid, addVehicleBtn, refreshBtn, new Label("All Vehicles:"), vehicleListView);
        vbox.setPadding(new Insets(15));

        Tab tab = new Tab("Manage Vehicles");
        tab.setContent(vbox);
        return tab;
    }

    private Tab createCustomersTab() {
        TextField idField = new TextField();
        TextField nameField = new TextField();
        Button addCustomerBtn = new Button("Add Customer");
        addCustomerBtn.setOnAction(e -> {
            try {
                int id = Integer.parseInt(idField.getText().trim());
                String name = nameField.getText().trim();
                if (system.addCustomer(new Customer(id, name))) {
                    showInfo("Customer added successfully!");
                    refreshCustomers();
                }
            } catch (Exception ex) {
                showError("Invalid customer data");
            }
        });

        Button refreshBtn = new Button("Refresh Customer List");
        refreshBtn.setOnAction(e -> refreshCustomers());

        VBox vbox = new VBox(10,
                new Label("Customer ID:"), idField,
                new Label("Name:"), nameField,
                addCustomerBtn,
                refreshBtn,
                new Label("All Customers:"),
                customerListView);
        vbox.setPadding(new Insets(15));

        Tab tab = new Tab("Manage Customers");
        tab.setContent(vbox);
        return tab;
    }

    private Tab createRentReturnTab() {
        Button refreshCombosBtn = new Button("Refresh Lists");
        refreshCombosBtn.setOnAction(e -> refreshRentReturnCombos());

        Button rentBtn = new Button("Rent Selected Vehicle");
        rentBtn.setOnAction(e -> rentVehicleAction());

        Button returnBtn = new Button("Return Selected Vehicle");
        returnBtn.setOnAction(e -> returnVehicleAction());

        VBox vbox = new VBox(15,
                new Label("Available Vehicles:"), rentVehicleCombo,
                new Label("Customer (by ID):"), rentCustomerCombo,
                new Label("Rental Amount:"), rentAmountField,
                rentBtn,
                new Separator(),
                new Label("Rented Vehicles:"), returnVehicleCombo,
                new Label("Customer (by ID):"), returnCustomerCombo,
                new Label("Extra Fees:"), returnFeesField,
                returnBtn,
                refreshCombosBtn);

        vbox.setPadding(new Insets(15));

        Tab tab = new Tab("Rent / Return");
        tab.setContent(vbox);
        return tab;
    }

    private Tab createHistoryTab() {
        Button refreshHistoryBtn = new Button("Refresh History");
        refreshHistoryBtn.setOnAction(e -> refreshHistory());

        VBox vbox = new VBox(10, refreshHistoryBtn, new Label("Full Rental History:"), historyListView);
        vbox.setPadding(new Insets(15));

        Tab tab = new Tab("Rental History");
        tab.setContent(vbox);
        return tab;
    }

    private void addVehicle() {
        try {
            String type = vehicleTypeCombo.getValue();
            String plate = plateField.getText().trim().toUpperCase();
            String make = makeField.getText().trim();
            String model = modelField.getText().trim();
            int year = Integer.parseInt(yearField.getText().trim());

            Vehicle vehicle = null;
            switch (type) {
                case "Car":
                    int seats = Integer.parseInt(seatsField.getText().trim());
                    vehicle = new Car(make, model, year, seats);
                    break;
                case "SportCar":
                    int sSeats = Integer.parseInt(seatsField.getText().trim());
                    int hp = Integer.parseInt(horsepowerField.getText().trim());
                    boolean turbo = turboCheck.isSelected();
                    vehicle = new SportCar(make, model, year, sSeats, hp, turbo);
                    break;
                case "Minibus":
                    boolean accessible = accessibleCheck.isSelected();
                    vehicle = new Minibus(make, model, year, accessible);
                    break;
                case "PickupTruck":
                    double cargo = Double.parseDouble(cargoField.getText().trim());
                    boolean trailer = trailerCheck.isSelected();
                    vehicle = new PickupTruck(make, model, year, cargo, trailer);
                    break;
            }

            if (vehicle != null) {
                vehicle.setLicensePlate(plate);
                if (system.addVehicle(vehicle)) {
                    showInfo("Vehicle added successfully!");
                    refreshVehicles();
                }
            }
        } catch (Exception ex) {
            showError("Invalid vehicle data - please check all fields");
        }
    }

    private void rentVehicleAction() {
        String plate = rentVehicleCombo.getValue();
        String custIdStr = rentCustomerCombo.getValue();
        if (plate == null || custIdStr == null) {
            showError("Please select vehicle and customer");
            return;
        }
        try {
            int custId = Integer.parseInt(custIdStr);
            double amount = Double.parseDouble(rentAmountField.getText().trim());

            Vehicle v = system.findVehicleByPlate(plate);
            Customer c = system.findCustomerById(custId);

            if (v != null && c != null) {
                system.rentVehicle(v, c, LocalDate.now(), amount);
                showInfo("Vehicle rented!");
                refreshRentReturnCombos();
                refreshHistory();
            }
        } catch (Exception ex) {
            showError("Invalid rental data");
        }
    }

    private void returnVehicleAction() {
        String plate = returnVehicleCombo.getValue();
        String custIdStr = returnCustomerCombo.getValue();
        if (plate == null || custIdStr == null) {
            showError("Please select vehicle and customer");
            return;
        }
        try {
            int custId = Integer.parseInt(custIdStr);
            double fees = Double.parseDouble(returnFeesField.getText().trim());

            Vehicle v = system.findVehicleByPlate(plate);
            Customer c = system.findCustomerById(custId);

            if (v != null && c != null) {
                system.returnVehicle(v, c, LocalDate.now(), fees);
                showInfo("Vehicle returned!");
                refreshRentReturnCombos();
                refreshHistory();
            }
        } catch (Exception ex) {
            showError("Invalid return data");
        }
    }

    private void refreshAll() {
        refreshVehicles();
        refreshCustomers();
        refreshRentReturnCombos();
        refreshHistory();
    }

    private void refreshVehicles() {
        List<Vehicle> vehicles = system.getAllVehicles();
        vehicleListView.getItems().clear();
        for (Vehicle v : vehicles) {
            String display = v.getLicensePlate() + " | " + v.getClass().getSimpleName() +
                    " | " + v.getMake() + " " + v.getModel() + " | " + v.getStatus();
            vehicleListView.getItems().add(display);
        }
    }

    private void refreshCustomers() {
        List<Customer> customers = system.getAllCustomers();
        customerListView.getItems().clear();
        for (Customer c : customers) {
            customerListView.getItems().add(c.getCustomerId() + " - " + c.getCustomerName());
        }
    }

    private void refreshRentReturnCombos() {
        rentVehicleCombo.getItems().clear();
        system.getAllVehicles().stream()
                .filter(v -> v.getStatus() == Vehicle.VehicleStatus.Available)
                .forEach(v -> rentVehicleCombo.getItems().add(v.getLicensePlate()));

        returnVehicleCombo.getItems().clear();
        system.getAllVehicles().stream()
                .filter(v -> v.getStatus() == Vehicle.VehicleStatus.Rented)
                .forEach(v -> returnVehicleCombo.getItems().add(v.getLicensePlate()));

        rentCustomerCombo.getItems().clear();
        returnCustomerCombo.getItems().clear();
        system.getAllCustomers().forEach(c -> {
            String entry = String.valueOf(c.getCustomerId());
            rentCustomerCombo.getItems().add(entry);
            returnCustomerCombo.getItems().add(entry);
        });
    }

    private void refreshHistory() {
        historyListView.getItems().clear();
        for (RentalRecord r : system.getRentalHistory()) {
            historyListView.getItems().add(r.toString());
        }
    }

    private void showInfo(String message) {
        Alert alert = new Alert(Alert.AlertType.INFORMATION);
        alert.setContentText(message);
        alert.showAndWait();
    }

    private void showError(String message) {
        Alert alert = new Alert(Alert.AlertType.ERROR);
        alert.setContentText(message);
        alert.showAndWait();
    }

    public static void main(String[] args) {
        launch(args);
    }
}